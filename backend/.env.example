# Application Node Environment
NODE_ENV="development"
PORT=3000

# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/elixir_oak?schema=public"

# Redis Cache & Queues Configuration
REDIS_URL="redis://127.0.0.1:6379"

# JWT Authentication Secrets
JWT_SECRET="super-secret-access-token-key-change-in-production-at-least-32-chars"
JWT_REFRESH_SECRET="super-secret-refresh-token-key-change-in-production-at-least-32-chars"

# Razorpay Keys (Staging/Production)
RAZORPAY_KEY_ID="rzp_test_change_me"
RAZORPAY_KEY_SECRET="rzp_secret_change_me"

# Transactional SMTP Mail Client Settings (Nodemailer)
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="smtp_username_here"
SMTP_PASS="smtp_password_here"

# Sentry Error Monitoring DSN
SENTRY_DSN="https://example_key@sentry.io/example_project"

# OpenTelemetry Exporter Endpoint
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318/v1/traces"
