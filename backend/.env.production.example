# =============================================================================
# Elixir & Oak — Production Environment Configuration
# Copy to .env.production and fill in all secrets before deployment.
# =============================================================================
NODE_ENV="production"
PORT=3000

# Database
DATABASE_URL="postgresql://elixir_oak_user:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:5432/elixir_oak?schema=public"

# Redis
REDIS_URL="redis://:CHANGE_ME_REDIS_PASSWORD@127.0.0.1:6379"

# JWT Authentication
JWT_SECRET="<generate: openssl rand -base64 48>"
JWT_REFRESH_SECRET="<generate: openssl rand -base64 48>"

# Razorpay (Production Keys from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID="rzp_live_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="rzp_live_secret_xxxxxxxxxxxx"
RAZORPAY_WEBHOOK_SECRET="rzp_webhook_xxxxxxxxxxxx"

# SMTP (Transactional Email)
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT=587
SMTP_USER="apikey"
SMTP_PASS="SG.xxxxxxxxxxxxxxxxxxxx"

# Sentry Error Tracking
SENTRY_DSN="https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXX"

# WhatsApp Notifications
WHATSAPP_ENABLED="true"
WHATSAPP_OWNER_NUMBER="+919999999999"

# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=""
